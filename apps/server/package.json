{
  "name": "@panda-chat-widget/server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "node --watch src/main.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json --pretty false",
    "start": "node dist/main.js",
    "test": "node --test \"src/**/*.test.ts\" \"test/**/*.test.mjs\"",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "check": "pnpm typecheck && pnpm build && pnpm test",
    "db:migrate": "node dist/migrate.js",
    "db:seed": "node dist/seed.js",
    "local-panda:dispatch-dry-run": "node dist/local-panda-dispatch-dry-run-cli.js",
    "local-panda:reply-round-trip": "node dist/local-panda-reply-round-trip-cli.js",
    "local-panda:reply-manual": "node dist/local-panda-reply-manual-cli.js",
    "local-panda:reply-ingress-apply": "node dist/local-panda-reply-ingress-apply-cli.js",
    "local-panda:reply-ingress-build": "node dist/local-panda-reply-ingress-build-cli.js",
    "local-panda:delivery-status": "node dist/local-panda-delivery-status-cli.js"
  },
  "description": "Owns the future API, database, and SSE service for the chat widget.",
  "dependencies": {
    "fastify": "^5.8.5",
    "kysely": "^0.29.2",
    "pg": "^8.22.0",
    "@panda-chat-widget/shared": "workspace:*"
  },
  "type": "module",
  "devDependencies": {
    "@types/pg": "^8.20.0"
  }
}
